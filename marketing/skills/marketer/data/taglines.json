  "avoid_patterns": [
    {
      "pattern": "Anything with \"OS,\" \"operating system,\" or \"ecosystem\"",
      "reason": "Does not fit aviation brand voice."
    },
    {
      "pattern": "\"All-in-one\"",
      "reason": "Overused SaaS cliche."
    },
    {
      "pattern": "\"Next-gen\" or \"reimagined\"",
      "reason": "Buzzwords pilots distrust."
    },
    {
      "pattern": "\"For the modern pilot\"",
      "reason": "Implies older pilots aren't welcome."
    },
    {
      "pattern": "\"Disrupting aviation\"",
      "reason": "No one in GA wants to hear this."
    },
    {
      "pattern": "\"The Uber of...\" or \"The [consumer brand] of flying\"",
      "reason": "Cringe in aviation culture."
    },
    {
      "pattern": "\"Fly smarter\" as a standalone",
      "reason": "Too vague without context."
    },
    {
      "pattern": "\"Revolutionize your flying\"",
      "reason": "Oversells and undersells simultaneously."
    }
  ],
